# Same backend as the web app; only override for staging/local.
EXPO_PUBLIC_API_BASE_URL=https://successapi.azurewebsites.net/api/

# Optional: deployed web app origin for external links.
# EXPO_PUBLIC_WEB_APP_URL=https://your-web-app.example.com

# Fast2SMS key for mobile registration OTP (same as web Account_UI).
# EXPO_PUBLIC_FAST2SMS_KEY=your_fast2sms_key

# Optional: Google Cloud Translation — improves English-word → regional language suggestions.
# EXPO_PUBLIC_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key
