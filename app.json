{
  "expo": {
    "name": "My Success",
    "slug": "account-ui-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.successprabu.aimobileapp"
    },
    "android": {
      "label": "My Success",
      "package": "com.successprabu.aimobileapp",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-speech-recognition",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos for receipt import."
        }
      ]
    ]
  }
}
